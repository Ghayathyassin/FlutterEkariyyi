# Template for android/key.properties — COPY this to `key.properties` (same
# folder) and fill in your real values. `key.properties` is git-ignored and must
# NEVER be committed: it points at your private signing keystore.
#
# storeFile: absolute path to the .jks you generated with keytool. On Windows use
# forward slashes (C:/Users/you/keys/upload-keystore.jks) or double backslashes.
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
storeFile=C:/Users/gyassine/keys/upload-keystore.jks
